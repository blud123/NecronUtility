{
  "schemaVersion": 1,
  "id": "dw-addons",
  "version": "${version}",
  "name": "DW Addons",
  "description": "DW Addons for Meteor Client.",
  "authors": [
    "deWinter"
  ],
  "contact": {
    "sources": "https://github.com/deWinterr/NecronUtility"
  },
  "icon": "assets/dw-addons/icon.png",
  "accessWidener": "dw-addons.accesswidener",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.example.addon.DWAddons"
    ]
  },
  "mixins": [
    "dw-addons.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  }
}
